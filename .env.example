# =============================================================================
# AWS Community Showcase — Environment Variables Template
# =============================================================================
# Copy this to .env.local and fill in real values. Never commit .env.local.
# Required vars are validated at import time — `npm run dev` and `npm test`
# will throw immediately if any are missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (REQUIRED)
# Dashboard → Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by /api routes (admin client) and the property tests.
# NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Supabase CLI (OPTIONAL)
# Only needed if you run `supabase link` / migrations locally.
# -----------------------------------------------------------------------------
SUPABASE_PROJECT_REF=your-project-ref

# -----------------------------------------------------------------------------
# Site URL (OPTIONAL — defaults to http://localhost:3000)
# Used by Server Components (e.g. /showcase) to fetch internal /api routes.
# Set this to the deployed origin in production (e.g. https://your-app.vercel.app)
# so server-side fetches resolve correctly.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
